# Relay configuration
PORT=8080

# Single-user lockdown: only this GitHub user id may connect.
# Find yours: curl -H "Authorization: Bearer <token>" https://api.github.com/user
VSRCHAT_ALLOWED_GITHUB_IDS=123456
VSRCHAT_ALLOWED_GITHUB_LOGINS=dragoscv

VSRCHAT_MAX_PEERS=4
VSRCHAT_IDLE_TIMEOUT_MS=300000
